# ============================================================
# Przykładowe zmienne środowiskowe dla VS Code + GitHub Copilot
# Skopiuj ten plik do `.env`, uzupełnij wartości i uruchom:
#   .\scripts\set-environment-variables.ps1
# ============================================================

# GitHub Personal Access Token dla MCP GitHub
# Utwórz na: https://github.com/settings/tokens
# Minimalne zakresy: repo, read:user
GITHUB_TOKEN=

# Brave Search API Key dla researchu webowego MCP
# Utwórz na: https://brave.com/search/api
BRAVE_API_KEY=

# Magic UI API Key dla generowania komponentów UI (opcjonalne)
# Utwórz na: https://21st.dev
MAGIC_UI_API_KEY=
